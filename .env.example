# Exocortex configuration. Copy this file to `.env` and edit. All keys
# are optional — sensible defaults are baked into `Settings` if absent.

# ── Memory chat (RAG over memory) ──────────────────────────────────
# Off by default; toggle on with `precog chat-toggle on`. When ON,
# requires a local Ollama instance reachable at the endpoint below.

# Where Ollama is listening
EXOCORTEX_MEMORY_CHAT_ENDPOINT=http://localhost:11434

# Pin a chat model. Empty string = auto-detect via /api/tags
# (picks the first non-embedding model). Examples: qwen2.5:7b, llama3.1:8b
EXOCORTEX_MEMORY_CHAT_CHAT_MODEL=

# Embedding model (used by v1+ semantic retrieval; v0 retrieval is FTS-only)
EXOCORTEX_MEMORY_CHAT_EMBEDDING_MODEL=nomic-embed-text

# How many records to retrieve per chat query
EXOCORTEX_MEMORY_CHAT_DEFAULT_TOP_K=8

# Cap on tokens generated per answer
EXOCORTEX_MEMORY_CHAT_MAX_TOKENS=1024

# Timeout (seconds) on Ollama API calls
EXOCORTEX_MEMORY_CHAT_TIMEOUT_SECONDS=60

# ── Storage paths ──────────────────────────────────────────────────
# Where the audit log + memory.db + flag files live. Relative paths
# resolve from the daemon's current working directory.
# EXOCORTEX_DATA_DIR=./data
# EXOCORTEX_AUDIT_LOG_PATH=./data/audit.jsonl
# EXOCORTEX_MEMORY_DB_PATH=./data/memory.db

# ── User profile ───────────────────────────────────────────────────
# Identifier for the operator the profile is "about" (USER scope).
# EXOCORTEX_PROFILE_USER_ID=operator

# ── Logging ────────────────────────────────────────────────────────
# EXOCORTEX_LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR
# EXOCORTEX_LOG_FORMAT=console    # console | json

# ── Web server hardening (A2) ──────────────────────────────────────
# The operator UI trusts a local browser. The guard rejects cross-origin
# browser traffic (CSRF + cross-site WebSocket hijack); loopback origins
# are always allowed and non-browser clients (CLI/curl) are unaffected.
# Extra browser origins allowed to reach the API / event socket, CSV:
# EXOCORTEX_WEB_ALLOWED_ORIGINS=http://192.168.1.5:8756
# Require this token on every /api/* call + the WebSocket (header
# X-Exocortex-Token or ?token=). Empty = pure loopback trust.
# EXOCORTEX_WEB_TOKEN=

# ── Tool sandbox for ad-hoc MCP fs/shell calls (A1) ────────────────
# fs_read / fs_list / shell_exec from an attached agent are routed
# through the policy engine, confined to this root, and audited. Secret
# paths (.ssh/.aws/.env/keys) are denied regardless. Defaults to the
# process working directory. Widen deliberately if agents need more.
# EXOCORTEX_TOOL_SANDBOX_ROOT=.
# When false, an out-of-policy fs write / shell exec in autonomous
# dispatch is auto-DENIED instead of auto-approved (the choice is
# explicit + audited either way).
# EXOCORTEX_DISPATCH_AUTO_APPROVE_TOOLS=true
